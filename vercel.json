{
    "version": 2,
    "builds": [
          { "src": "analyse.js", "use": "@vercel/node" },
          { "src": "create-checkout.js", "use": "@vercel/node" },
          { "src": "verify-session.js", "use": "@vercel/node" },
          { "src": "webhook.js", "use": "@vercel/node" },
          { "src": "index.html", "use": "@vercel/static" }
    ],
    "routes": [
          { "src": "/api/analyse", "dest": "/analyse.js" },
          { "src": "/api/create-checkout", "dest": "/create-checkout.js" },
          { "src": "/api/verify-session", "dest": "/verify-session.js" },
          { "src": "/api/webhook", "dest": "/webhook.js" },
          { "src": "/(.*)", "dest": "/index.html" }
    ],
    "env": {
          "ANTHROPIC_API_KEY": "@anthropic_api_key",
          "STRIPE_SECRET_KEY": "@stripe_secret_key",
          "STRIPE_WEBHOOK_SECRET": "@stripe_webhook_secret",
          "TOKEN_SECRET": "@token_secret"
    }
}
